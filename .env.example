APP_NAME="Helpdesk Confipetrol"
# ⚠ Para producción usar: APP_ENV=production, APP_DEBUG=false
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_TIMEZONE=America/Bogota

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Throttle de login (Fortify). En producción mantener en 5.
# Se sube temporalmente a 1000 en desarrollo para pruebas E2E.
FORTIFY_LOGIN_LIMIT=5

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=helpdesk
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DUMP_BINARY_PATH=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# Activar en true para producción con datos sensibles
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# LLM: "openrouter" (free models) or "anthropic" (Claude)
# ⚠ NUNCA commitear el API key real.
# ⚠ En producción migrar a Claude/Azure OpenAI (ver docs/pendientes.md P0)
LLM_PROVIDER=openrouter
LLM_MODEL="meta-llama/llama-3.1-8b-instruct:free"
LLM_API_KEY=
LLM_EMBEDDING_MODEL="nomic-ai/nomic-embed-text-v1.5"

# Feature flag: botón "Redactar con IA" en creación de KB articles.
# Auto-desactivado si LLM_API_KEY está vacío.
ENABLE_AI_KB_DRAFT=true

# Azure AD (Entra ID) SSO
# ⚠ AZURE_TENANT_ID DEBE ser el ID del tenant corporativo.
# Si se deja en "common" o vacío, el callback ABORTA (protección contra
# login con cuentas personales de Microsoft).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI="${APP_URL}/auth/azure/callback"

# Dominios cuyos correos pueden iniciar sesión vía Azure SSO.
# Separar múltiples dominios con coma. El callback rechaza cualquier
# correo con dominio fuera de esta lista.
AZURE_ALLOWED_DOMAINS=confipetrol.com
